          "xxhdpi": "static/app-icon/icon-144.png",
          "xxxhdpi": "static/app-icon/icon-192.png"
        },
        "ios": {
          "appstore": "static/app-icon/icon-1024.png",
          "ipad": {
            "app": "static/app-icon/icon-76.png",
            "app@2x": "static/app-icon/icon-152.png",
            "notification": "static/app-icon/icon-20.png",
            "notification@2x": "static/app-icon/icon-40.png",
            "proapp@2x": "static/app-icon/icon-167.png",
            "settings": "static/app-icon/icon-29.png",
            "settings@2x": "static/app-icon/icon-58.png",
            "spotlight": "static/app-icon/icon-40.png",
            "spotlight@2x": "static/app-icon/icon-80.png"
